<Window x:Class="VCSyncBackupApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="VC Sync Backup"
        Icon="Assets/vcsync-logo.png"
        Width="1280"
        Height="820"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A"
        FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#111827" />
        <SolidColorBrush x:Key="BorderBrush" Color="#334155" />
        <SolidColorBrush x:Key="TextBrush" Color="#E2E8F0" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#14B8A6" />
        <SolidColorBrush x:Key="DangerBrush" Color="#EF4444" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1F2937" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E293B" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="200" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.4*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Padding="18" CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Background="#111827">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontSize="26" FontWeight="Bold" Text="VChannel Backup Automation" />
                    <TextBlock Margin="0,4,0,0" Foreground="{StaticResource MutedTextBrush}" Text="Outline VPN server backup manager with selective archive and retention" />
                    <ProgressBar Margin="0,12,20,0" Height="10" Minimum="0" Maximum="100" Value="{Binding OverallProgress}" />
                    <TextBlock Margin="0,6,0,0" Foreground="{StaticResource MutedTextBrush}" Text="{Binding OverallProgress, StringFormat=Overall Progress: {0}%}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding StartBackupCommand}" MinWidth="140" Content="Backup All" />
                    <Button Command="{Binding StopBackupCommand}" MinWidth="110" Background="#B91C1C" Content="Stop" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Margin="0,14,10,12" Padding="12" CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Background="{StaticResource PanelBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Server Management" />

                <DataGrid Grid.Row="1"
                          Margin="0,10,0,8"
                          ItemsSource="{Binding Servers}"
                          SelectedItem="{Binding SelectedServer}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          ColumnHeaderHeight="34"
                          RowBackground="#0B1220"
                          AlternatingRowBackground="#111827"
                          Background="#0B1220"
                          Foreground="{StaticResource TextBrush}"
                          BorderBrush="{StaticResource BorderBrush}"
                          GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="1.1*" />
                        <DataGridTextColumn Header="IP Address" Binding="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}" Width="1.1*" />
                        <DataGridTextColumn Header="Remote Data Path" Binding="{Binding RemoteDataPath, UpdateSourceTrigger=PropertyChanged}" Width="1.5*" />
                        <DataGridTextColumn Header="Remote Config Path" Binding="{Binding RemoteConfigPath, UpdateSourceTrigger=PropertyChanged}" Width="1.5*" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" IsReadOnly="True" Width="0.8*" />
                        <DataGridTemplateColumn Header="Progress" Width="1*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <ProgressBar Minimum="0" Maximum="100" Value="{Binding ProgressPercent}" Height="14" />
                                        <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Text="{Binding ProgressDetail}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Click="AddServerButton_OnClick" Content="Add" />
                    <Button Command="{Binding DeleteServerCommand}" Background="{StaticResource DangerBrush}" Content="Delete" />
                    <Button Command="{Binding ImportServersCommand}" Background="#0369A1" Content="Import JSON" />
                    <Button Command="{Binding ExportServersCommand}" Background="#0369A1" Content="Export JSON" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" Margin="10,14,0,0" Padding="12" CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Background="{StaticResource PanelBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Configuration" />

                <TextBlock Grid.Row="1" Margin="0,14,0,4" Text="WinSCPnet.dll Path" />
                <DockPanel Grid.Row="2">
                    <TextBox Text="{Binding WinScpAssemblyPath, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Command="{Binding BrowseAssemblyCommand}" Margin="8,0,0,0" Content="Browse" />
                </DockPanel>

                <TextBlock Grid.Row="3" Margin="0,12,0,4" Text="Private Key (.ppk)" />
                <DockPanel Grid.Row="4">
                    <TextBox Text="{Binding PrivateKeyPath, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Command="{Binding BrowseKeyCommand}" Margin="8,0,0,0" Content="Browse" />
                </DockPanel>

                <TextBlock Grid.Row="5" Margin="0,12,0,4" Text="Private Key Passphrase" />
                <PasswordBox Grid.Row="6"
                             Name="PassphraseBox"
                             PasswordChanged="PassphraseBox_OnPasswordChanged"
                             Background="#1F2937"
                             Foreground="{StaticResource TextBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1"
                             Padding="8,6" />

                <ScrollViewer Grid.Row="7" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,4" Text="Base Backup Directory" />
                        <DockPanel>
                            <TextBox Text="{Binding BaseBackupDirectory, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Command="{Binding BrowseBaseDirectoryCommand}" Margin="8,0,0,0" Content="Browse" />
                        </DockPanel>

                        <TextBlock Margin="0,12,0,4" Text="Retention Count (keep latest N zip files)" />
                        <TextBox Text="{Binding RetentionCount, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="8" Margin="0,12,0,0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,10,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button MinWidth="100" Background="#0EA5A0" Click="AboutButton_OnClick" Content="About" />
                        <Button Command="{Binding SaveSettingsCommand}" Content="Save Settings" />
                        <Button Command="{Binding StartBackupCommand}" Content="Start Backup" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2" Grid.Column="0" Margin="0,0,10,0" Padding="12" CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Background="#020617">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock FontSize="17" FontWeight="SemiBold" Text="Execution Logs" />
                    <CheckBox Grid.Column="1"
                              Name="PauseAutoScrollCheckBox"
                              VerticalAlignment="Center"
                              Margin="10,0,0,0"
                              Foreground="{StaticResource MutedTextBrush}"
                              Content="Pause auto-scroll"
                              Checked="PauseAutoScrollCheckBox_OnChecked"
                              Unchecked="PauseAutoScrollCheckBox_OnUnchecked" />
                </Grid>
                <TextBox Grid.Row="1"
                         Name="LogTextBox"
                         Margin="0,8,0,0"
                         Text="{Binding LogText}"
                         IsReadOnly="True"
                         TextChanged="LogTextBox_OnTextChanged"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         FontFamily="Consolas"
                         Background="#020617"
                         BorderBrush="{StaticResource BorderBrush}" />
            </Grid>
        </Border>

        <Border Grid.Row="3" Grid.ColumnSpan="2" Margin="0,10,0,0" Padding="10,8" CornerRadius="10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Background="#0B1220">
            <TextBlock HorizontalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Text="Copyright (c) VChannel All Rights Reserved" />
        </Border>
    </Grid>
</Window>
