<Window x:Class="VCSyncBackupApp.AddServerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Server"
        Width="560"
        Height="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0F172A"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E2E8F0" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1F2937" />
            <Setter Property="Foreground" Value="#E2E8F0" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#334155" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="6,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Border CornerRadius="12" BorderBrush="#334155" BorderThickness="1" Background="#111827" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,14" FontSize="19" FontWeight="SemiBold" Text="Add New Server" />

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,10" VerticalAlignment="Center" Text="Name" />
                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,10" Name="NameTextBox" />

                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,10" VerticalAlignment="Center" Text="IP Address" />
                <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,10" Name="IpTextBox" />

                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,10" VerticalAlignment="Center" Text="Remote Data Path" />
                <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,10" Name="RemoteDataPathTextBox" />

                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,8,10" VerticalAlignment="Top" Text="Remote Config Path" />
                <TextBox Grid.Row="4" Grid.Column="1" Height="34" VerticalAlignment="Top" Name="RemoteConfigPathTextBox" />

                <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Width="96" Click="CancelButton_OnClick" Content="Cancel" />
                    <Button Width="96" Background="#14B8A6" Click="SaveButton_OnClick" Content="Add" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
